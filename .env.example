NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_for_local_demo
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/change_me_for_local_demo

# "local" (default) or "openrouter"
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=google/gemma-4-E4B-it
LLM_API_KEY=not-needed

# Required only when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=replace_with_your_openrouter_key
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Set to 1 to run the API with deterministic offline sample responses.
LEGALQA_DEMO=0
